# Ignore Vagrant and VirtualBox files
.vagrant/
*.box
*.log
*.pid
*.swp

# Ignore system files
.DS_Store
Thumbs.db

# Ignore editor/project files
*.code-workspace
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Ignore Python cache
__pycache__/
*.pyc
*.pyo

# Ignore backup files
*~
*.bak

# Ignore environment files
.env
.env.*

# Ignore node_modules (if using Node.js in any part)
node_modules/
